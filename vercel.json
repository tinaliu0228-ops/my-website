{
  "version": 2,
  "builds": [
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/stats",
      "dest": "/stats.html"
    },
    {
      "src": "/qr",
      "dest": "/qr.html"
    }
  ]
}